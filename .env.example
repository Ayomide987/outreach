# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (optional — enables Google Sign-In) ──────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.herokuapp.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Heroku / Railway / Render — don't set it locally
# PORT=8000

# ── Gmail (configure via the app Settings page after deploying) ───────────────
# These are stored in the database; you don't need to set them here.
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
